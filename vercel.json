{
  "version": 2,
  "experimentalServices": {
    "crm-api": {
      "entrypoint": ".",
      "routePrefix": "/",
      "framework": "nestjs",
      "memory": 1024,
      "maxDuration": 30,
      "includeFiles": ["dist/**", "node_modules/.prisma/**"]
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
